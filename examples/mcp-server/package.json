{
  "name": "@stbr/solana-glossary-mcp",
  "version": "1.0.0",
  "description": "MCP Server that exposes the Solana Glossary as intelligent tools for LLMs — lookup, search, concept exploration, and learning paths.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "solana-glossary-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "inspector": "npx -y @modelcontextprotocol/inspector tsx src/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@stbr/solana-glossary": "file:../../"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "solana",
    "glossary",
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "web3"
  ],
  "license": "MIT"
}
